#!/usr/bin/env bash
#SBATCH --job-name=euf-viper-resources
#SBATCH --partition=cpu_idle
#SBATCH --cpus-per-task=1
#SBATCH --mem=8G
#SBATCH --time=01:00:00
#SBATCH --output=results/wmi-resources-%j.out
#SBATCH --error=results/wmi-resources-%j.err

set -euo pipefail

ROOT="${EUF_VIPER_ROOT:-${SLURM_SUBMIT_DIR:-$PWD}}"
BASELINE_BIN="${EUF_VIPER_RESOURCE_BASELINE_BIN:?set EUF_VIPER_RESOURCE_BASELINE_BIN}"
CANDIDATE_BIN="${EUF_VIPER_RESOURCE_CANDIDATE_BIN:?set EUF_VIPER_RESOURCE_CANDIDATE_BIN}"
MANIFEST="${EUF_VIPER_RESOURCE_MANIFEST:?set EUF_VIPER_RESOURCE_MANIFEST}"
TIMEOUT="${EUF_VIPER_RESOURCE_TIMEOUT:-5}"
REPEATS="${EUF_VIPER_RESOURCE_REPEATS:-3}"
LIMIT="${EUF_VIPER_RESOURCE_LIMIT:-0}"
RUN_ID="${EUF_VIPER_RESOURCE_RUN_ID:-$SLURM_JOB_ID}"
OUTPUT_PREFIX="${EUF_VIPER_RESOURCE_OUTPUT_PREFIX:-$ROOT/results/wmi-resources-$RUN_ID}"

cd "$ROOT"
mkdir -p results "$(dirname "$OUTPUT_PREFIX")"
test -x "$BASELINE_BIN"
test -x "$CANDIDATE_BIN"
test -x /usr/bin/time
test -s "$MANIFEST"

sha256sum "$BASELINE_BIN" "$CANDIDATE_BIN" "$MANIFEST" /usr/bin/time

ARGS=(
  "$MANIFEST"
  --baseline "$BASELINE_BIN"
  --candidate "$CANDIDATE_BIN"
  --baseline-env "EUF_VIPER_BACKEND=${EUF_VIPER_RESOURCE_BASELINE_BACKEND:-auto}"
  --candidate-env "EUF_VIPER_BACKEND=${EUF_VIPER_RESOURCE_CANDIDATE_BACKEND:-auto}"
  --baseline-env "EUF_VIPER_DIRECT_ROOT_CNF=${EUF_VIPER_RESOURCE_BASELINE_DIRECT_ROOT_CNF:-1}"
  --candidate-env "EUF_VIPER_DIRECT_ROOT_CNF=${EUF_VIPER_RESOURCE_CANDIDATE_DIRECT_ROOT_CNF:-1}"
  --baseline-env "EUF_VIPER_DIRECT_NEGATED_ROOT=${EUF_VIPER_RESOURCE_BASELINE_DIRECT_NEGATED_ROOT:-0}"
  --candidate-env "EUF_VIPER_DIRECT_NEGATED_ROOT=${EUF_VIPER_RESOURCE_CANDIDATE_DIRECT_NEGATED_ROOT:-0}"
  --baseline-env "EUF_VIPER_UNCONDITIONAL_QUOTIENT=${EUF_VIPER_RESOURCE_BASELINE_UNCONDITIONAL_QUOTIENT:-off}"
  --candidate-env "EUF_VIPER_UNCONDITIONAL_QUOTIENT=${EUF_VIPER_RESOURCE_CANDIDATE_UNCONDITIONAL_QUOTIENT:-off}"
  --baseline-env "EUF_VIPER_SCOPED_LET=${EUF_VIPER_RESOURCE_BASELINE_SCOPED_LET:-auto}"
  --candidate-env "EUF_VIPER_SCOPED_LET=${EUF_VIPER_RESOURCE_CANDIDATE_SCOPED_LET:-auto}"
  --baseline-env "EUF_VIPER_INVALID_MODEL_FALLBACK=${EUF_VIPER_RESOURCE_BASELINE_INVALID_MODEL_FALLBACK:-cadical-refine}"
  --candidate-env "EUF_VIPER_INVALID_MODEL_FALLBACK=${EUF_VIPER_RESOURCE_CANDIDATE_INVALID_MODEL_FALLBACK:-cadical-refine}"
  --baseline-env "EUF_VIPER_REFINEMENT_MODE=${EUF_VIPER_RESOURCE_BASELINE_REFINEMENT_MODE:-current}"
  --candidate-env "EUF_VIPER_REFINEMENT_MODE=${EUF_VIPER_RESOURCE_CANDIDATE_REFINEMENT_MODE:-current}"
  --baseline-env "EUF_VIPER_EQ_ABSTRACTION=${EUF_VIPER_RESOURCE_BASELINE_EQ_ABSTRACTION:-off}"
  --candidate-env "EUF_VIPER_EQ_ABSTRACTION=${EUF_VIPER_RESOURCE_CANDIDATE_EQ_ABSTRACTION:-off}"
  --baseline-env "EUF_VIPER_EQ_ABSTRACTION_FRESH=${EUF_VIPER_RESOURCE_BASELINE_EQ_ABSTRACTION_FRESH:-0}"
  --candidate-env "EUF_VIPER_EQ_ABSTRACTION_FRESH=${EUF_VIPER_RESOURCE_CANDIDATE_EQ_ABSTRACTION_FRESH:-0}"
  --baseline-env "EUF_VIPER_FINITE_EQUALITY_CHANNELING=${EUF_VIPER_RESOURCE_BASELINE_FINITE_EQUALITY_CHANNELING:-value-only}"
  --candidate-env "EUF_VIPER_FINITE_EQUALITY_CHANNELING=${EUF_VIPER_RESOURCE_CANDIDATE_FINITE_EQUALITY_CHANNELING:-value-only}"
  --baseline-env "EUF_VIPER_FINITE_PREDICATE_CHANNELING=${EUF_VIPER_RESOURCE_BASELINE_FINITE_PREDICATE_CHANNELING:-0}"
  --candidate-env "EUF_VIPER_FINITE_PREDICATE_CHANNELING=${EUF_VIPER_RESOURCE_CANDIDATE_FINITE_PREDICATE_CHANNELING:-0}"
  --baseline-env "EUF_VIPER_FINITE_DOMAIN_MAX=${EUF_VIPER_RESOURCE_BASELINE_FINITE_DOMAIN_MAX:-11}"
  --candidate-env "EUF_VIPER_FINITE_DOMAIN_MAX=${EUF_VIPER_RESOURCE_CANDIDATE_FINITE_DOMAIN_MAX:-11}"
  --baseline-env "EUF_VIPER_FINITE_DOMAIN=${EUF_VIPER_RESOURCE_BASELINE_FINITE_DOMAIN:-0}"
  --candidate-env "EUF_VIPER_FINITE_DOMAIN=${EUF_VIPER_RESOURCE_CANDIDATE_FINITE_DOMAIN:-0}"
  --baseline-env "EUF_VIPER_FINITE_SYMMETRY=${EUF_VIPER_RESOURCE_BASELINE_FINITE_SYMMETRY:-hybrid}"
  --candidate-env "EUF_VIPER_FINITE_SYMMETRY=${EUF_VIPER_RESOURCE_CANDIDATE_FINITE_SYMMETRY:-hybrid}"
  --baseline-env "EUF_VIPER_FINITE_SYMMETRY_MIN_APPS=${EUF_VIPER_RESOURCE_BASELINE_FINITE_SYMMETRY_MIN_APPS:-1000}"
  --candidate-env "EUF_VIPER_FINITE_SYMMETRY_MIN_APPS=${EUF_VIPER_RESOURCE_CANDIDATE_FINITE_SYMMETRY_MIN_APPS:-1000}"
  --baseline-env "EUF_VIPER_FINITE_LEX_MIN_DOMAIN=${EUF_VIPER_RESOURCE_BASELINE_FINITE_LEX_MIN_DOMAIN:-8}"
  --candidate-env "EUF_VIPER_FINITE_LEX_MIN_DOMAIN=${EUF_VIPER_RESOURCE_CANDIDATE_FINITE_LEX_MIN_DOMAIN:-8}"
  --baseline-env "EUF_VIPER_FINITE_PERMUTATION_SUPPORT=${EUF_VIPER_RESOURCE_BASELINE_FINITE_PERMUTATION_SUPPORT:-0}"
  --candidate-env "EUF_VIPER_FINITE_PERMUTATION_SUPPORT=${EUF_VIPER_RESOURCE_CANDIDATE_FINITE_PERMUTATION_SUPPORT:-0}"
  --baseline-env "EUF_VIPER_CADICAL_MODE=${EUF_VIPER_RESOURCE_BASELINE_CADICAL_MODE:-plain}"
  --candidate-env "EUF_VIPER_CADICAL_MODE=${EUF_VIPER_RESOURCE_CANDIDATE_CADICAL_MODE:-plain}"
  --baseline-env "EUF_VIPER_CADICAL_SEARCH_MODE=${EUF_VIPER_RESOURCE_BASELINE_CADICAL_SEARCH_MODE:-auto}"
  --candidate-env "EUF_VIPER_CADICAL_SEARCH_MODE=${EUF_VIPER_RESOURCE_CANDIDATE_CADICAL_SEARCH_MODE:-auto}"
  --baseline-env "EUF_VIPER_AXIOM_ORDER=${EUF_VIPER_RESOURCE_BASELINE_AXIOM_ORDER:-native}"
  --candidate-env "EUF_VIPER_AXIOM_ORDER=${EUF_VIPER_RESOURCE_CANDIDATE_AXIOM_ORDER:-native}"
  --timeout "$TIMEOUT"
  --repeats "$REPEATS"
  --out "${OUTPUT_PREFIX}.csv"
  --summary "${OUTPUT_PREFIX}.json"
)
if [ "$LIMIT" -gt 0 ]; then
  ARGS+=(--limit "$LIMIT")
fi

scripts/bench/compare_viper_resources.py "${ARGS[@]}"
sha256sum "${OUTPUT_PREFIX}.csv" "${OUTPUT_PREFIX}.json"
